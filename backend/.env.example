# Database configuration (PostgreSQL or MySQL)
# Example PostgreSQL: postgresql://postgres:postgres@localhost:5432/crm_db
# Example MySQL: mysql+pymysql://root:password@localhost:3306/crm_db
# Fallback: SQLite is used if DATABASE_URL is not set or is empty.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_db

# Groq API Configuration
GROQ_API_KEY=gsk_...
